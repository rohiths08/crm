{
  "name": "ai-crm-importer-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "AI-powered CSV Import API for CRM data extraction",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
